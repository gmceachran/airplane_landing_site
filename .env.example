# Optional: full URL or path (e.g. /warehouse.jpg in public/). Defaults below if unset.
# VITE_HERO_IMAGE_URL=/warehouse.jpg

# Only needed for GitHub project-page URLs (https://<user>.github.io/<repo>/).
# Leave unset for local dev and for custom-domain / apex hosting (default: /).
# VITE_BASE_PATH=/your-repo-name/

# Shown in mailto links and placeholder store page until a backend exists.
VITE_CONTACT_EMAIL=chaseproctor@roswellaero.com

# Optional: POST endpoint for the email signup form (e.g. Formspree, Basin, your API).
# If empty, submit opens a mailto draft instead.
# VITE_LEAD_FORM_ENDPOINT=
